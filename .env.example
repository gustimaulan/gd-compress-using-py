# Copy this file to .env and fill in your values

# A long random string used to sign sessions (required).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Optional: Set a password to protect the web UI.
# Leave blank to disable authentication.
APP_PASSWORD=

# Google OAuth credentials (from Google Cloud Console -> APIs & Services -> Credentials)
# Set these to skip uploading credentials.json. App type must be "Web application",
# and https://yourdomain.com/api/oauth/callback must be an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of allowed Google emails (leave empty to allow any)
ALLOWED_EMAILS=you@gmail.com

# Your public domain (used by Traefik for routing)
APP_DOMAIN=gd-compressor.yourdomain.com

# Port the Flask app listens on inside the container (default: 5000)
PORT=5000
