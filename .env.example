# Copy this file to .env and fill in your values

# A long random string used to sign sessions (required).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Google OAuth credentials (from Google Cloud Console -> APIs & Services -> Credentials)
# App type must be "Web application".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The domain where the Flask backend is accessible (used to build the OAuth callback URL).
# For local dev: http://localhost:5001
# For production: https://gdc.gmdhia.my.id
APP_DOMAIN=http://localhost:5001

# Port the Flask app listens on (default: 5001)
PORT=5001
